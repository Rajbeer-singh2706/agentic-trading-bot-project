# Environment Configuration
# Copy this file to .env and fill in with your values

# API Keys
OPENAI_API_KEY=your_openai_api_key_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Trading Configuration
TRADING_MODE=paper  # paper or live
TRADING_ACCOUNT_ID=your_account_id
TRADING_API_KEY=your_trading_api_key

# Database
DATABASE_URL=sqlite:///./agentic_trading_bot.db
# DATABASE_URL=postgresql://user:password@localhost/agentic_trading_bot

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/app.log

# Server Configuration
HOST=0.0.0.0
PORT=8000
DEBUG=False

# Agent Configuration
AGENT_TIMEOUT=300
MAX_RETRIES=3
